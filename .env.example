# Configuración de Wompi para FloraSmart
# Copia este archivo como .env y completa los valores reales

# API Keys de Wompi (Obtén estas del dashboard de Wompi)
WOMPI_PUBLIC_KEY=your_public_key_here
WOMPI_PRIVATE_KEY=your_private_key_here

# URLs de redirección después del pago
WOMPI_REDIRECT_URL=http://localhost:8000/pagos/wompi/retorno/
WOMPI_WEBHOOK_URL=http://localhost:8000/pagos/wompi/webhook/

# Cloudinary (opcional, pero necesario para guardar medios en producción)
CLOUDINARY_CLOUD_NAME=dno17p0t7
CLOUDINARY_API_KEY=823155341951451
CLOUDINARY_API_SECRET=WJgW5aP5R6xMB_ralrW4_sH9FSU

# Notas:
# 1. Registra tu aplicación en https://sandbox.wompi.co para obtener las claves de prueba
# 2. En producción, usa las URLs con tu dominio real
# 3. Configura el webhook en el dashboard de Wompi para que apunte a WOMPI_WEBHOOK_URL
# 4. Los pagos en sandbox pueden procesarse con tarjetas de prueba de Wompi
